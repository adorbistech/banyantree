{
  "name": "banyantree",
  "displayName": "BanyanTree",
  "description": "Persistent repository cognition — remembers WHY your code is the way it is",
  "version": "0.1.0",
  "publisher": "adorbis",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["cognition", "memory", "architecture", "context", "ai"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{
        "id": "banyantree",
        "title": "BanyanTree",
        "icon": "$(circuit-board)"
      }]
    },
    "views": {
      "banyantree": [
        {
          "type": "webview",
          "id": "banyantree.memoryPanel",
          "name": "Memory"
        },
        {
          "type": "webview",
          "id": "banyantree.graphPanel",
          "name": "Graph"
        }
      ]
    },
    "commands": [
      {
        "command": "banyantree.rememberThis",
        "title": "BanyanTree: Remember This"
      },
      {
        "command": "banyantree.forgetThis",
        "title": "BanyanTree: Forget This Memory"
      },
      {
        "command": "banyantree.correctThis",
        "title": "BanyanTree: Correct This Memory"
      },
      {
        "command": "banyantree.showContext",
        "title": "BanyanTree: Show File Context"
      },
      {
        "command": "banyantree.openDoctor",
        "title": "BanyanTree: Run Doctor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "banyantree.rememberThis",
          "group": "banyantree@1"
        },
        {
          "command": "banyantree.showContext",
          "group": "banyantree@2"
        }
      ]
    },
    "configuration": {
      "title": "BanyanTree",
      "properties": {
        "banyantree.runtimePort": {
          "type": "number",
          "default": 7842,
          "description": "Port the BanyanTree runtime daemon listens on"
        },
        "banyantree.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable BanyanTree cognition tracking"
        },
        "banyantree.showOnFileOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically surface memory context when opening a file"
        },
        "banyantree.minWeightToShow": {
          "type": "number",
          "default": 0.3,
          "description": "Minimum memory weight to display in sidebar (0.0–1.0)"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "dev": "npm run build -- --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0"
  }
}
